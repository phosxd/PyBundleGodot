# Normalize line endings for all files that Git considers text files.
* text=auto eol=lf

# Only include the addons folder when downloading from the Asset Library.
/**             export-ignore
/src !export-ignore
/src/addons !export-ignore
/src/addons/BinBundle !export-ignore
/src/addons/BinBundle/** !export-ignore
/src/addons/PyBundle !export-ignore
/src/addons/PyBundle/** !export-ignore

# Don't include UID files.
*.uid export-ignore
